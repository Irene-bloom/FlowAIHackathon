# ==============================================
# FlowAI - 环境变量模板
# ==============================================
# 使用方式：
#   1. 复制本文件为 .env  (cp .env.example .env)
#   2. 填入真实值
#   3. .env 已在 .gitignore 里，不会被推到 GitHub
# ==============================================

# ---------- 火山方舟 (Volcengine Ark) ----------
# 控制台: https://console.volcengine.com/ark
# 需要先创建"在线推理接入点"拿到 endpoint id (ep-xxx)

ARK_API_KEY=your_ark_api_key_here
ARK_ENDPOINT_ID=ep-xxxxxxxxxxxxxxxxx
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ---------- 备用 LLM (可选) ----------
# OPENAI_API_KEY=

# ---------- 应用配置 ----------
APP_ENV=dev
LOG_LEVEL=INFO
